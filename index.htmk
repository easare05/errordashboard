})();


// Users
function getUserColor(uid){const u=db.users.find(u=>u.id===uid);if(!u)return'#6b7280';return AVATAR_COLORS[db.users.indexOf(u)%AVATAR_COLORS.length];}
function getUserInitials(uid){const u=db.users.find(u=>u.id===uid);if(!u)return'?';return u.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);}
function getUserName(uid){const u=db.users.find(u=>u.id===uid);return u?u.name:'Unknown';}
function avatarHtml(uid,size=32){const col=getUserColor(uid),init=getUserInitials(uid);return`<div class="user-avatar" style="width:${size}px;height:${size}px;background:${col}20;color:${col};font-size:${size>30?12:10}px;font-weight:600">${init}</div>`;}

function populateUploaderSelect(){
  const sel=document.getElementById('uploader-select');const cur=sel.value;
  sel.innerHTML='<option value="">Select team member...</option>';
  db.users.forEach(u=>{const o=document.createElement('option');o.value=u.id;o.textContent=u.name+(u.role?` (${u.role})`:'');sel.appendChild(o);});
  sel.value=cur;
}

function showAddUserModal(){
  const chk=document.getElementById('platform-checkboxes');
  chk.innerHTML=ALL_PLATFORMS.map(p=>`<label style="display:flex;align-items:center;gap:5px;font-size:13px;cursor:pointer"><input type="checkbox" value="${p}" style="margin:0;width:14px;height:14px"> ${p}</label>`).join('');
  document.getElementById('add-user-modal').classList.add('open');
  document.getElementById('new-user-name').value='';document.getElementById('new-user-role').value='';
}
function hideAddUserModal(){document.getElementById('add-user-modal').classList.remove('open');}
document.getElementById('add-user-modal').addEventListener('click',e=>{if(e.target===e.currentTarget)hideAddUserModal();});

function addUser(){
  const name=document.getElementById('new-user-name').value.trim();
  if(!name){alert('Please enter a name.');return;}
  const role=document.getElementById('new-user-role').value.trim();
  const platforms=[...document.querySelectorAll('#platform-checkboxes input:checked')].map(i=>i.value);
  db.users.push({id:'u'+Date.now(),name,role,platforms,addedAt:new Date().toISOString(),active:true});
  saveDB();hideAddUserModal();populateUploaderSelect();renderTeamList();renderCoverageGrid();populateAdminFilters();
}
function toggleUserActive(uid){const u=db.users.find(u=>u.id===uid);if(u)u.active=!u.active;saveDB();renderTeamList();}
function deleteUser(uid){if(!confirm('Remove this team member?'))return;db.users=db.users.filter(u=>u.id!==uid);saveDB();populateUploaderSelect();renderTeamList();renderCoverageGrid();populateAdminFilters();}

function renderTeamList(){
  const el=document.getElementById('team-list');
  if(!db.users.length){el.innerHTML='<div class="empty">No team members added yet. Click "Add team member" to get started.</div>';return;}
  el.innerHTML=db.users.map(u=>{
    const uploads=db.uploadLog.filter(l=>l.userId===u.id).length;
    const last=db.uploadLog.filter(l=>l.userId===u.id).sort((a,b)=>b.ts.localeCompare(a.ts))[0];
    return`<div class="user-row">
      ${avatarHtml(u.id,40)}
      <div style="flex:1">
        <div style="font-weight:500;font-size:14px">${u.name}</div>
        <div style="font-size:12px;color:var(--text2)">${u.role||'No role set'}</div>
        <div style="margin-top:5px">${u.platforms&&u.platforms.length?u.platforms.map(p=>`<span class="platform-pill">${p}</span>`).join(''):'<span style="font-size:11px;color:var(--text3)">No platforms assigned</span>'}</div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-size:12px;color:var(--text2)">${uploads} upload${uploads!==1?'s':''}</div>
        ${last?`<div style="font-size:11px;color:var(--text3);margin-top:2px">Last: ${new Date(last.ts).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}</div>`:''}
        <div style="margin-top:8px;display:flex;gap:6px;justify-content:flex-end">
          <span onclick="toggleUserActive('${u.id}')" style="cursor:pointer;font-size:11px" class="cat-badge" style="background:${u.active?'#d1fae5':'#f3f4f6'};color:${u.active?'#065f46':'#6b7280'}">${u.active?'Active':'Inactive'}</span>
          <button class="danger" onclick="deleteUser('${u.id}')" style="font-size:12px;padding:3px 10px">Remove</button>
        </div>
      </div>
    </div>`;
  }).join('');
}

function parseAndStore(filenameHint){
  const text=document.getElementById('paste-area').value.trim();
  const label=document.getElementById('report-label').value.trim()||`Report ${db.reports.length+1}`;
  const uploaderId=document.getElementById('uploader-select').value;
  if(!text){showUploadStatus('Please paste report text or upload a file.','warn');return;}
  const{data,expected}=parseReport(text);
  if(!data.length){showUploadStatus('No errors found — check the report format.','warn');return;}
  const fp=filenameHint?inferPlatformFromFilename(filenameHint):null;
  if(fp)data.forEach(row=>{if(row.platform==='Unknown'||row.platform==='DM-Unknown')row.platform=fp;});
  const reportId='r'+Date.now(),ts=new Date().toISOString();
  const platforms=[...new Set(data.map(r=>r.platform).filter(p=>p!=='Unknown'&&p!=='DM-Unknown'))];
  db.reports.push({id:reportId,label,ts,count:data.length,expected,platforms,uploadedBy:uploaderId||null});
  data.forEach(row=>db.errors.push({...row,reportId,reportLabel:label,ts}));
  db.uploadLog.push({id:'l'+Date.now(),reportId,reportLabel:label,userId:uploaderId||null,ts,platforms,errorCount:data.length,expected,matched:data.length===expected});
  saveDB();
  const note=expected>0?(data.length===expected?` — all ${expected} matched`:` — stated ${expected}, parsed ${data.length}`):'';
  showUploadStatus(`Stored ${data.length} errors from "${label}"${note}.`+(uploaderId?` Logged to ${getUserName(uploaderId)}.`:''),'ok');
  document.getElementById('paste-area').value='';document.getElementById('report-label').value='';
  renderOverview();renderHistoryList();populateFilters();renderAdminLog();renderTeamList();renderCoverageGrid();
}
document.getElementById('fileIn').addEventListener('change',e=>{
  const file=e.target.files[0];if(!file)return;
  if(!document.getElementById('report-label').value)document.getElementById('report-label').value=file.name.replace(/\.txt$/i,'').replace(/_/g,' ');
  const reader=new FileReader();
  reader.onload=ev=>{document.getElementById('paste-area').value=ev.target.result;parseAndStore(file.name);};
  reader.readAsText(file);e.target.value='';
});
function showUploadStatus(msg,type){const el=document.getElementById('upload-status');el.className=type==='ok'?'status-ok':'status-warn';el.textContent=msg;}

const SAMPLE=`Errors (5):
- Firm Evolution Financial Planning Ltd had 1 errors:
    - Adviser Rebecca Robertson had 1 errors:
        - Client Melanie Coeshott (AV2743862) had 1 errors:
            - Error importing account DM2317036 and its holdings: "Firm Evolution Financial Planning Ltd doesn't have access to portfolios named Timeline Tracker 90"
- Firm Jones & Co Advisers Ltd had 2 errors:
    - Adviser Joshua Walker had 2 errors:
        - Client Fiona Barrand (EM1694701) had 1 errors:
            - Couldn't match any holding ISIN code for account DM1429368
        - Client Erin Hancock Investment (EM1619781) had 1 errors:
            - Error importing account DM1406706 and its holdings: "Account DM1406706 balance is less than or equal to £100"
- Firm Harvest Associates had 1 errors:
    - Adviser Andrew Boulton had 1 errors:
        - Client Kevin Snell (13848) had 1 errors:
            - Error importing account 23831 and its holdings: "Error importing account: the account 23831 belongs to a client from a different firm, so it won't be updated"
- Firm Corbel Partners Limited had 1 errors:
    - Adviser Kevin Anthony Hamblin error:
        - Couldn't match adviser Kevin Anthony Hamblin to an existing adviser`;
function loadSample(){document.getElementById('report-label').value='Sample — Multi-platform';document.getElementById('paste-area').value=SAMPLE;}

// Platform / badges
function platformColor(p){return{Aviva:'#2563eb','True Potential':'#16a34a',Transact:'#7c3aed',Wealthtime:'#d97706',Quilter:'#ea580c',Fidelity:'#db2777','7IM':'#059669','Scottish Widows':'#6b7280',ABRDN:'#4f46e5',Nucleus:'#ca8a04'}[p]||'#6b7280';}
function platformBadge(p){const c={Aviva:'b-aviva','True Potential':'b-tp',Transact:'b-transact',Wealthtime:'b-wealthtime',Quilter:'b-quilter',Fidelity:'b-fidelity','7IM':'b-7im','Scottish Widows':'b-sw',ABRDN:'b-abrdn',Nucleus:'b-nucleus'}[p]||'b-unknown';return`<span class="badge ${c}">${p}</span>`;}
function countBy(arr,key){const c={};arr.forEach(r=>{const v=r[key]||'Unknown';c[v]=(c[v]||0)+1;});return Object.entries(c).sort((a,b)=>b[1]-a[1]);}
function renderBars(cid,entries,colorFn){
  const el=document.getElementById(cid);if(!entries.length){el.innerHTML='<div class="empty">No data</div>';return;}
  const m=entries[0][1]||1;
  el.innerHTML=entries.slice(0,8).map(([label,count])=>`<div class="bar-row"><div class="bar-label" title="${label}">${label}</div><div class="bar-track"><div class="bar-fill" style="width:${Math.round(count/m*100)}%;background:${colorFn(label)}"></div></div><div class="bar-count" style="color:var(--text2)">${count}</div></div>`).join('');
}

let activeCatFilter=null;
function renderCatFilterChips(){
  const chips=document.getElementById('cat-filter-chips');
  const counts={};db.errors.forEach(e=>{const c=e.category||'unknown';counts[c]=(counts[c]||0)+1;});
  chips.innerHTML=`<span class="cat-chip${!activeCatFilter?' active':''}" onclick="setCatFilter(null)" style="background:var(--surface2);color:var(--text2);${!activeCatFilter?'border-color:var(--text)':''}">All</span>`+
    Object.keys(CAT_DEFS).filter(k=>counts[k]).map(k=>{const c=CAT_DEFS[k];const ia=activeCatFilter===k;return`<span class="cat-chip${ia?' active':''}" onclick="setCatFilter('${k}')" style="background:${c.bg};color:${c.text};${ia?`border-color:${c.color}`:'border-color:transparent'}">${c.label} <strong>${counts[k]||0}</strong></span>`;}).join('');
}
function setCatFilter(cat){activeCatFilter=cat;renderCatFilterChips();renderErrorLog();}

function _fill(id,items){
  const el=document.getElementById(id);if(!el)return;
  const cur=el.value;
  while(el.options.length>1)el.remove(1);
  items.forEach(function(item){const o=document.createElement('option');o.value=item.v;o.textContent=item.l||item.v;el.appendChild(o);});
  el.value=[...el.options].some(function(o){return o.value===cur;})?cur:'';
}
function pf(){
  var errors=db.errors;
  var vp=document.getElementById('fp')?document.getElementById('fp').value:'';
  var vc=document.getElementById('fc')?document.getElementById('fc').value:'';
  var vrep=document.getElementById('frep')?document.getElementById('frep').value:'';
  var vfi=document.getElementById('ffi')?document.getElementById('ffi').value:'';
  var vad=document.getElementById('fad')?document.getElementById('fad').value:'';
  _fill('fp',[...new Set(errors.map(function(e){return e.platform;}).filter(Boolean))].sort().map(function(v){return{v:v};}));
  var p1=vp?errors.filter(function(e){return e.platform===vp;}):errors;
  var cats=[...new Set(p1.map(function(e){return e.category;}).filter(Boolean))].sort(function(a,b){return(CAT_DEFS[a]?CAT_DEFS[a].label:a).localeCompare(CAT_DEFS[b]?CAT_DEFS[b].label:b);});
  _fill('fc',cats.map(function(c){return{v:c,l:CAT_DEFS[c]?CAT_DEFS[c].label:c};}));
  var repIds=new Set(p1.map(function(e){return e.reportId;}));
  _fill('frep',[...db.reports].filter(function(r){return repIds.has(r.id);}).reverse().map(function(r){return{v:r.id,l:r.label};}));
  var p2=p1.filter(function(e){return(!vc||e.category===vc)&&(!vrep||e.reportId===vrep);});
  _fill('ffi',[...new Set(p2.map(function(e){return e.firm;}).filter(Boolean))].sort().map(function(v){return{v:v};}));
  var p3=p2.filter(function(e){return!vfi||e.firm===vfi;});
  _fill('fad',[...new Set(p3.map(function(e){return e.adviser;}).filter(Boolean))].sort().map(function(v){return{v:v};}));
  var p4=p3.filter(function(e){return!vad||e.adviser===vad;});
  _fill('fcl',[...new Set(p4.map(function(e){return e.client;}).filter(Boolean))].sort().map(function(v){return{v:v};}));
  renderCatFilterChips();
}
function populateFilters(){pf();}
function clearFilters(){
  ['fp','fc','fr','fst','frep','ffi','fad','fcl'].forEach(function(id){var el=document.getElementById(id);if(el)el.value='';});
  var fs=document.getElementById('filter-search');if(fs)fs.value='';
  activeCatFilter=null;pf();renderErrorLog();
}

var _elSort={key:null,dir:1};
var _rowKeys={};
var _hiddenCols=new Set();
function sortEL(th){
  var k=th.dataset.key;
  document.querySelectorAll('#elt th.sortable').forEach(function(h){h.classList.remove('sort-asc','sort-desc');});
  if(_elSort.key===k){_elSort.dir*=-1;}else{_elSort.key=k;_elSort.dir=1;}
  th.classList.add(_elSort.dir===1?'sort-asc':'sort-desc');
  renderErrorLog();
}
function togCol(btn){
  var c=parseInt(btn.dataset.col);
  if(_hiddenCols.has(c)){_hiddenCols.delete(c);btn.classList.add('on');}
  else{_hiddenCols.add(c);btn.classList.remove('on');}
  _applyHidden();
}
function _applyHidden(){
  var t=document.getElementById('elt');if(!t)return;
  for(var i=0;i<=7;i++){
    var show=!_hiddenCols.has(i);
    t.querySelectorAll('th:nth-child('+(i+1)+'),td:nth-child('+(i+1)+')').forEach(function(c){c.style.display=show?'':'none';});
  }
}
function _eKey(e){return(e.accountId||'')+'|'+(e.reportId||'')+'|'+(e.error||'').slice(0,60);}
function toggleResolvedIdx(cb){
  var idx=parseInt(cb.dataset.idx);
  var k=_rowKeys[idx];
  if(!k)return;
  toggleResolved(k);
}
function toggleResolved(k){
  if(!db.resolved)db.resolved={};
  if(db.resolved[k])delete db.resolved[k];else db.resolved[k]={ts:new Date().toISOString()};
  saveDB();renderErrorLog();renderOverview();
}
function renderErrorLog(){
  if(!db.resolved)db.resolved={};
  var vp=document.getElementById('fp')?document.getElementById('fp').value:'';
  var vc=document.getElementById('fc')?document.getElementById('fc').value:'';
  var vr=document.getElementById('fr')?document.getElementById('fr').value:'';
  var vst=document.getElementById('fst')?document.getElementById('fst').value:'';
  var vrep=document.getElementById('frep')?document.getElementById('frep').value:'';
  var vfi=document.getElementById('ffi')?document.getElementById('ffi').value:'';
  var vad=document.getElementById('fad')?document.getElementById('fad').value:'';
  var vcl=document.getElementById('fcl')?document.getElementById('fcl').value:'';
  var fq=(document.getElementById('filter-search')?document.getElementById('filter-search').value:'').toLowerCase();
  var filtered=db.errors.filter(function(e){
    if(vp&&e.platform!==vp)return false;
    if(vc&&e.category!==vc)return false;
    if(vr&&e.resolution!==vr)return false;
    if(activeCatFilter&&e.category!==activeCatFilter)return false;
    if(vrep&&e.reportId!==vrep)return false;
    if(vfi&&e.firm!==vfi)return false;
    if(vad&&e.adviser!==vad)return false;
    if(vcl&&e.client!==vcl)return false;
    var isRes=!!(db.resolved[_eKey(e)]);
    if(vst==='open'&&isRes)return false;
    if(vst==='resolved'&&!isRes)return false;
    if(fq&&![e.client,e.adviser,e.accountId,e.error,e.firm].filter(Boolean).join(' ').toLowerCase().includes(fq))return false;
    return true;
  });
  if(_elSort.key){
    filtered=filtered.slice().sort(function(a,b){
      var av=(a[_elSort.key]||'').toString().toLowerCase();
      var bv=(b[_elSort.key]||'').toString().toLowerCase();
      return av<bv?-_elSort.dir:av>bv?_elSort.dir:0;
    });
  }
  var tbody=document.getElementById('error-log-body');
  var empty=document.getElementById('error-log-empty');
  var countEl=document.getElementById('error-log-count');
  if(!filtered.length){tbody.innerHTML='';empty.style.display='block';countEl.textContent='';return;}
  empty.style.display='none';
  _rowKeys={};
  var shown=filtered.slice(0,200);
  countEl.textContent='Showing '+shown.length+' of '+filtered.length+' errors';
  tbody.innerHTML=shown.map(function(r){
    var k=_eKey(r);
    var isRes=!!(db.resolved[k]);
    var rAt=isRes?new Date(db.resolved[k].ts).toLocaleDateString('en-GB',{day:'numeric',month:'short'}):null;
    _rowKeys[shown.indexOf(r)] = k;
    return '<tr class="'+(isRes?'is-res':'')+'">'
      +'<td>'+catBadge(r.category||'unknown')+'</td>'
      +'<td>'+platformBadge(r.platform)+'</td>'
      +'<td class="mono" style="font-size:12px;white-space:nowrap">'+(r.accountId||'—')+'</td>'
      +'<td style="white-space:nowrap">'+(r.client||'—')+'</td>'
      +'<td style="white-space:nowrap;font-size:12px;color:var(--text2)">'+(r.adviser||'—')+'</td>'
      +'<td style="white-space:nowrap;font-size:12px;color:var(--text2)">'+(r.firm||'—')+'</td>'
      +'<td><span style="font-size:11px;color:var(--text3)">'+(r.reportLabel||'')+'</span></td>'
      +'<td><div style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:12px;color:var(--text2)" title="'+r.error+'">'+r.error+'</div></td>'
      +'<td>'+(isRes?'<span class="st-pending">Pending next import</span>'+(rAt?'<div style="font-size:10px;color:var(--text3);margin-top:2px">Fixed '+rAt+'</div>':''):'<span class="st-open">Open</span>')+'</td>'
      +'<td style="text-align:center"><input type="checkbox" class="rcb" '+(isRes?'checked ':'')+' data-idx="'+shown.indexOf(r)+'" onchange="toggleResolvedIdx(this)"></td>'
      +'</tr>';
  }).join('');
  _applyHidden();
}

function renderOverview(){
  const errors=db.errors;
  document.getElementById('ov-total').textContent=errors.length.toLocaleString();
  const ua=new Set(errors.map(e=>e.accountId).filter(Boolean));document.getElementById('ov-accounts').textContent=ua.size.toLocaleString();
  document.getElementById('ov-reports').textContent=db.reports.length;
  const ac={};errors.filter(e=>e.accountId).forEach(e=>{ac[e.accountId]=(ac[e.accountId]||0)+1;});
  const rec=Object.entries(ac).filter(([,c])=>c>1);document.getElementById('ov-recurring').textContent=rec.length;
  renderBars('ov-platform-bars',countBy(errors,'platform'),platformColor);
  renderBars('ov-cat-bars',countBy(errors,'category'),cat=>CAT_DEFS[cat]?.color||'#6b7280');
  renderBars('ov-res-bars',countBy(errors,'resolution'),res=>RES_META[res]?.color||'#6b7280');
  const tr=rec.sort((a,b)=>b[1]-a[1]).slice(0,6);
  const rl=document.getElementById('ov-recurring-list');
  if(!tr.length){rl.innerHTML='<div class="empty">No recurring accounts yet — upload multiple reports to track recurring errors</div>';}
  else rl.innerHTML=`<div style="overflow-x:auto"><table><thead><tr><th>Account ID</th><th>Platform</th><th>Client</th><th>Errors</th><th>Reports</th><th>Category</th></tr></thead><tbody>${tr.map(([id,cnt])=>{const s=errors.find(e=>e.accountId===id)||{};const rp=new Set(errors.filter(e=>e.accountId===id).map(e=>e.reportId)).size;return`<tr style="cursor:pointer" onclick="openAccount('${id}')"><td class="mono" style="font-size:12px">${id}</td><td>${platformBadge(s.platform)}</td><td>${s.client||'—'}</td><td style="font-weight:600;color:#dc2626">${cnt}</td><td style="color:var(--text2)">${rp}</td><td>${catBadge(s.category||'unknown')}</td></tr>`;}).join('')}</tbody></table></div>`;
  const re=document.getElementById('ov-recent');
  if(!errors.length){re.innerHTML='<div class="empty">Upload a report to see errors here</div>';return;}
  const last=[...errors].reverse().slice(0,10);
  re.innerHTML=`<div style="overflow-x:auto"><table><thead><tr><th>Category</th><th>Platform</th><th>Account ID</th><th>Client</th><th>Report</th><th>Error</th></tr></thead><tbody>${last.map(r=>`<tr style="cursor:pointer" onclick="openAccount('${r.accountId||r.clientId||''}')"><td>${catBadge(r.category||'unknown')}</td><td>${platformBadge(r.platform)}</td><td class="mono" style="font-size:12px;white-space:nowrap">${r.accountId||'—'}</td><td style="white-space:nowrap">${r.client||'—'}</td><td><span style="font-size:11px;color:var(--text3)">${r.reportLabel||''}</span></td><td><div style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:12px;color:var(--text2)" title="${r.error}">${r.error}</div></td></tr>`).join('')}</tbody></table></div>`;
}

function renderAccountSearch(){
  const q=document.getElementById('acct-search').value.trim().toLowerCase(),el=document.getElementById('acct-results');
  if(!q){el.innerHTML='<div class="empty">Type above to search the error history database</div>';return;}
  if(!db.errors.length){el.innerHTML='<div class="empty">No data stored yet — upload a report first.</div>';return;}
  const matched=db.errors.filter(e=>(e.accountId&&e.accountId.toLowerCase().includes(q))||(e.clientId&&e.clientId.toLowerCase().includes(q))||(e.client&&e.client.toLowerCase().includes(q))||(e.adviser&&e.adviser.toLowerCase().includes(q)));
  if(!matched.length){el.innerHTML='<div class="empty">No matching accounts found</div>';return;}
  const grouped={};matched.forEach(e=>{const key=e.accountId||e.clientId||(e.client||'?')+'-'+(e.adviser||'');if(!grouped[key])grouped[key]=[];grouped[key].push(e);});
  el.innerHTML=Object.entries(grouped).map(([key,errs])=>renderAccountCard(key,errs)).join('');
}
function openAccount(id){if(!id)return;switchView('search');document.getElementById('acct-search').value=id;renderAccountSearch();}
function renderAccountCard(key,errs){
  const s=errs[0],dn=s.client||s.accountId||'Unknown';
  const init=dn.split(/\s+/).map(w=>w[0]).join('').toUpperCase().slice(0,2)||'?';
  const all=db.errors.filter(e=>{if(s.accountId)return e.accountId===s.accountId;if(s.clientId)return e.clientId===s.clientId;return e.client===s.client&&e.adviser===s.adviser;});
  const ra=new Set(all.map(e=>e.reportId)).size,ir=ra>1;
  const cats=[...new Set(all.map(e=>e.category||'unknown'))];
  return`<div class="acct-card"><div style="display:flex;align-items:center;gap:12px;margin-bottom:12px"><div class="initials-circle">${init}</div><div style="flex:1"><div style="font-weight:600;font-size:15px">${s.client||'Unknown client'}</div><div style="font-size:12px;color:var(--text2);margin-top:3px;display:flex;flex-wrap:wrap;gap:6px;align-items:center">${s.accountId?`<span class="id-pill">${s.accountId}</span>`:''}${s.clientId?`<span class="id-pill">${s.clientId}</span>`:''}${platformBadge(s.platform)}${cats.map(c=>catBadge(c)).join('')}</div></div><div style="text-align:right;flex-shrink:0">${ir?'<span class="badge b-recur">Recurring</span>':'<span class="badge b-new">New</span>'}<div style="font-size:12px;color:var(--text2);margin-top:4px">${all.length} error${all.length!==1?'s':''} · ${ra} report${ra!==1?'s':''}</div></div></div><div style="font-size:12px;color:var(--text2);margin-bottom:12px">Firm: ${s.firm||'—'} · Adviser: ${s.adviser||'—'}</div><div style="font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);margin-bottom:8px">Error timeline</div>${all.map((e,i)=>`<div style="display:flex;gap:8px;margin-bottom:4px"><div style="display:flex;flex-direction:column;align-items:center"><div class="timeline-dot" style="background:${CAT_DEFS[e.category||'unknown']?.color||'#6b7280'}"></div>${i<all.length-1?'<div class="timeline-line"></div>':''}</div><div style="flex:1;padding-bottom:8px"><div style="display:flex;align-items:center;gap:6px;margin-bottom:2px;flex-wrap:wrap">${catBadge(e.category||'unknown')}<span style="font-size:12px;font-weight:500">${e.reportLabel||'Unknown report'}</span><span style="font-size:11px;color:var(--text3)">${new Date(e.ts).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}</span></div><div style="font-size:12px;color:var(--text2)">${e.error}</div></div></div>`).join('')}</div>`;
}

function renderHistoryList(){
  const el=document.getElementById('history-list');
  if(!db.reports.length){el.innerHTML='<div class="empty">No reports uploaded yet</div>';return;}
  el.innerHTML=`<table><thead><tr><th>Label</th><th>Uploaded by</th><th>Platforms</th><th>Uploaded</th><th>Errors</th><th>Expected</th><th></th></tr></thead><tbody>${[...db.reports].reverse().map(r=>`<tr><td style="font-weight:500">${r.label}</td><td>${r.uploadedBy?`<div style="display:flex;align-items:center;gap:7px">${avatarHtml(r.uploadedBy,26)}<span style="font-size:13px">${getUserName(r.uploadedBy)}</span></div>`:'<span style="font-size:12px;color:var(--text3)">—</span>'}</td><td>${(r.platforms||[]).map(p=>platformBadge(p)).join(' ')||'—'}</td><td style="font-size:12px;color:var(--text2);white-space:nowrap">${new Date(r.ts).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})}</td><td style="font-weight:500">${r.count}</td><td>${r.expected>0?(r.count===r.expected?`<span style="color:#16a34a;font-weight:500">${r.expected} ✓</span>`:`<span style="color:#d97706">${r.expected}</span>`):'-'}</td><td><button class="danger" onclick="deleteReport('${r.id}')" style="font-size:12px;padding:4px 10px">Delete</button></td></tr>`).join('')}</tbody></table>`;
}
function deleteReport(rid){if(!confirm('Delete this report and all its errors?'))return;db.reports=db.reports.filter(r=>r.id!==rid);db.errors=db.errors.filter(e=>e.reportId!==rid);db.uploadLog=db.uploadLog.filter(l=>l.reportId!==rid);saveDB();renderOverview();renderHistoryList();populateFilters();renderAdminLog();}

function populateAdminFilters(){
  const us=document.getElementById('log-filter-user');const cur=us.value;
  us.innerHTML='<option value="">All team members</option>';
  db.users.forEach(u=>{const o=document.createElement('option');o.value=u.id;o.textContent=u.name;us.appendChild(o);});us.value=cur;
  const ps=document.getElementById('log-filter-platform');const curp=ps.value;
  ps.innerHTML='<option value="">All platforms</option>';
  ALL_PLATFORMS.forEach(p=>{const o=document.createElement('option');o.value=p;o.textContent=p;ps.appendChild(o);});ps.value=curp;
}

function renderAdminLog(){
  populateAdminFilters();
  const fu=document.getElementById('log-filter-user').value,fp=document.getElementById('log-filter-platform').value,fq=document.getElementById('log-filter-search').value.toLowerCase();
  const filtered=db.uploadLog.filter(l=>{
    if(fu&&l.userId!==fu)return false;if(fp&&!(l.platforms||[]).includes(fp))return false;
    if(fq&&!(l.reportLabel||'').toLowerCase().includes(fq))return false;return true;
  }).sort((a,b)=>b.ts.localeCompare(a.ts));
  const tbody=document.getElementById('admin-log-body'),empty=document.getElementById('admin-log-empty');
  if(!filtered.length){tbody.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  tbody.innerHTML=filtered.map(l=>`<tr>
    <td><div style="display:flex;align-items:center;gap:8px">${l.userId?avatarHtml(l.userId,30):'<div style="width:30px;height:30px;border-radius:50%;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--text3)">?</div>'}<div><div style="font-weight:500">${l.userId?getUserName(l.userId):'Not recorded'}</div>${l.userId&&db.users.find(u=>u.id===l.userId)?.role?`<div style="font-size:11px;color:var(--text3)">${db.users.find(u=>u.id===l.userId).role}</div>`:''}</div></div></td>
    <td style="font-weight:500">${l.reportLabel||'—'}</td>
    <td>${(l.platforms||[]).map(p=>platformBadge(p)).join(' ')||'<span style="color:var(--text3);font-size:12px">Unknown</span>'}</td>
    <td style="font-weight:500">${l.errorCount}</td>
    <td style="font-size:12px;color:var(--text2);white-space:nowrap">${new Date(l.ts).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}<br><span style="font-size:11px;color:var(--text3)">${new Date(l.ts).toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'})}</span></td>
    <td>${l.expected>0?(l.matched?'<span class="cat-badge" style="background:#dcfce7;color:#166534">Matched</span>':'<span class="cat-badge" style="background:#fef3c7;color:#92400e">Mismatch</span>'):'<span style="font-size:11px;color:var(--text3)">—</span>'}</td>
  </tr>`).join('');
}

function renderCoverageGrid(){
  const el=document.getElementById('coverage-grid');
  el.innerHTML=`<table><thead><tr><th>Platform</th><th>Last uploaded</th><th>By</th><th>Reports</th><th>Responsible</th></tr></thead><tbody>${ALL_PLATFORMS.map(p=>{
    const logs=db.uploadLog.filter(l=>(l.platforms||[]).includes(p)).sort((a,b)=>b.ts.localeCompare(a.ts));
    const last=logs[0];const responsible=db.users.filter(u=>(u.platforms||[]).includes(p));
    return`<tr><td>${platformBadge(p)}</td><td style="font-size:13px">${last?new Date(last.ts).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}):'<span style="color:var(--text3)">Never</span>'}</td><td>${last&&last.userId?`<div style="display:flex;align-items:center;gap:6px">${avatarHtml(last.userId,24)}<span style="font-size:12px">${getUserName(last.userId)}</span></div>`:'<span style="font-size:12px;color:var(--text3)">—</span>'}</td><td style="font-weight:500">${logs.length}</td><td>${responsible.length?responsible.map(u=>`<div style="display:flex;align-items:center;gap:5px;margin-bottom:2px">${avatarHtml(u.id,20)}<span style="font-size:12px">${u.name}</span></div>`).join(''):'<span style="font-size:12px;color:var(--text3)">Unassigned</span>'}</td></tr>`;
  }).join('')}</tbody></table>`;
}

function testPlatform(){
  const id=document.getElementById('test-id').value.trim(),el=document.getElementById('test-result');
  if(!id){el.innerHTML='';return;}
  if(isNucleusClientId(id)){el.innerHTML=platformBadge('Nucleus')+` <span style="font-size:12px;color:var(--text2)">Nucleus client ID</span>`;return;}
  if(/^\d{1,5}$/.test(id)){el.innerHTML=platformBadge('Wealthtime')+` <span style="font-size:12px;color:var(--text2)">Wealthtime ID</span>`;return;}
  const cp=detectClientIdPlatform(id);if(cp){el.innerHTML=platformBadge(cp)+` <span style="font-size:12px;color:var(--text2)">client ID</span>`;return;}
  const ap=detectPlatform(id,'');
  if(ap==='DM-Unknown')el.innerHTML=platformBadge('Unknown')+` <span style="font-size:12px;color:var(--text2)">DM — needs AV/AC/EM/WP client ID</span>`;
  else el.innerHTML=platformBadge(ap)+` <span style="font-size:12px;color:var(--text2)">account ID</span>`;
}

function adminTab(tab,btn){
  document.querySelectorAll('.admin-pane,[id^="admin-"]').forEach(p=>{if(['admin-log','admin-team','admin-coverage'].includes(p.id))p.style.display='none';});
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('admin-'+tab).style.display='block';
  if(btn)btn.classList.add('active');
  if(tab==='log')renderAdminLog();
  if(tab==='team')renderTeamList();
  if(tab==='coverage')renderCoverageGrid();
}

function switchView(name){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(b=>b.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  const map={overview:0,upload:1,errors:2,search:3,history:4,platforms:5,reconcile:6,admin:7};
  const items=document.querySelectorAll('.nav-item');
  if(map[name]!==undefined&&items[map[name]])items[map[name]].classList.add('active');
  if(name==='overview')renderOverview();
  if(name==='errors'){pf();renderCatFilterChips();renderErrorLog();}
  if(name==='history')renderHistoryList();
  if(name==='admin'){renderAdminLog();renderTeamList();renderCoverageGrid();}
}


// ── RECONCILIATION ────────────────────────────────────────────────────
var _reconRows = [];
var _reconResults = [];

function _normR(s) {
  return (s || '').toLowerCase().replace(/[^a-z0-9]/g, '');
}

function loadPlatFile(input) {
  var file = input.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    var rows = [];
    var fname = file.name.toLowerCase();
    if (fname.endsWith('.csv')) {
      var lines = e.target.result.replace(/\r/g, '').split('\n').filter(function(l) { return l.trim(); });
      var hdrs = lines[0].split(',').map(function(h) { return h.replace(/^"|"$/g, '').trim(); });
      rows = lines.slice(1).map(function(line) {
        var vals = line.split(/,(?=(?:[^"]*"[^"]*")*[^"]*$)/);
        var row = {};
        hdrs.forEach(function(h, i) { row[h] = (vals[i] || '').replace(/^"|"$/g, '').trim(); });
        return row;
      }).filter(function(r) { return Object.values(r).some(function(v) { return v; }); });
    } else {
      var wb = XLSX.read(e.target.result, {type: 'array'});
      rows = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], {defval: ''});
    }
    _reconRows = rows;
    var box = document.getElementById('ru-box');
    box.classList.add('ok');
    document.getElementById('ru-lbl').textContent = file.name + ' — ' + rows.length.toLocaleString() + ' rows';
    if (rows.length > 0) {
      var cols = Object.keys(rows[0]);
      ['rm-name', 'rm-id'].forEach(function(id, i) {
        var el = document.getElementById(id);
        while (el.options.length > 1) el.remove(1);
        cols.forEach(function(c) {
          var o = document.createElement('option');
          o.value = c; o.textContent = c; el.appendChild(o);
        });
        var ng = cols.find(function(c) { return /client.?name|investor|full.?name|^name$/i.test(c); });
        var ig = cols.find(function(c) { return /wrapper.?ref|account.?id|client.?id|^id$/i.test(c); });
        if (i === 0 && ng) el.value = ng;
        if (i === 1 && ig) el.value = ig;
      });
      var fn = file.name.toLowerCase();
      var ps = document.getElementById('rm-plat');
      if (fn.includes('transact'))           ps.value = 'Transact';
      else if (fn.includes('aviva'))         ps.value = 'Aviva';
      else if (fn.includes('quilter'))       ps.value = 'Quilter';
      else if (fn.includes('abrdn') || fn.includes('aberdeen')) ps.value = 'ABRDN';
      else if (fn.includes('nucleus'))       ps.value = 'Nucleus';
      else if (fn.includes('fidelity'))      ps.value = 'Fidelity';
      else if (fn.includes('wealthtime'))    ps.value = 'Wealthtime';
      else if (fn.includes('scottish'))      ps.value = 'Scottish Widows';
      else if (fn.includes('true_potential'))ps.value = 'True Potential';
      else if (fn.includes('seven') || fn.includes('7im')) ps.value = '7IM';
    }
    _checkBothLoaded();
    input.value = '';
  };
  if (file.name.toLowerCase().endsWith('.csv')) {
    reader.readAsText(file);
  } else {
    reader.readAsArrayBuffer(file);
  }
}

// Internal dashboard data loaded by user
var _internalRows = [];

function loadInternalFile(input) {
  var file = input.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    var rows = [];
    if (file.name.toLowerCase().endsWith('.csv')) {
      var lines = e.target.result.replace(/\r/g, '').split('\n').filter(function(l) { return l.trim(); });
      var hdrs = lines[0].split(',').map(function(h) { return h.replace(/^"|"$/g, '').trim(); });
      rows = lines.slice(1).map(function(line) {
        var vals = line.split(/,(?=(?:[^"]*"[^"]*")*[^"]*$)/);
        var row = {};
        hdrs.forEach(function(h, i) { row[h] = (vals[i] || '').replace(/^"|"$/g, '').trim(); });
        return row;
      }).filter(function(r) { return Object.values(r).some(function(v) { return v; }); });
    } else {
      var wb = XLSX.read(e.target.result, {type: 'array'});
      rows = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], {defval: ''});
    }
    _internalRows = rows;
    var box = document.getElementById('ri-box');
    box.classList.add('ok');
    document.getElementById('ri-lbl').textContent = file.name + ' — ' + rows.length.toLocaleString() + ' accounts loaded';
    input.value = '';
    _checkBothLoaded();
  };
  file.name.toLowerCase().endsWith('.csv') ? reader.readAsText(file) : reader.readAsArrayBuffer(file);
}

function _checkBothLoaded() {
  if (_internalRows.length > 0 && _reconRows.length > 0) {
    document.getElementById('rs2').style.display = 'block';
  }
}

function runRecon() {
  var nameCol = document.getElementById('rm-name').value;
  var idCol   = document.getElementById('rm-id').value;
  var platform = document.getElementById('rm-plat').value;
  if (!nameCol) { alert('Please select the client name column.'); return; }
  if (_internalRows.length === 0) { alert('Please upload the internal dashboard export first.'); return; }
  // Build lookup from uploaded internal dashboard file
  var intNames = new Set();
  var intIds   = new Set();
  var intNameCol = 'Account owner';
  var intIdCol   = 'Account ID';
  var intPlatCol = 'Platform';
  // Auto-detect columns
  if (_internalRows.length > 0) {
    var cols = Object.keys(_internalRows[0]);
    var nc = cols.find(function(c) { return /account.?owner|client.?name|full.?name|^name$/i.test(c); }) || cols[0];
    var ic = cols.find(function(c) { return /account.?id|^id$/i.test(c); });
    var pc = cols.find(function(c) { return /^platform$/i.test(c); });
    intNameCol = nc; intIdCol = ic || ''; intPlatCol = pc || '';
  }
  _internalRows.forEach(function(r) {
    var rPlat = intPlatCol ? (r[intPlatCol] || '') : '';
    // Normalise platform names to match error report names
    var platMap = {'Abrdn':'ABRDN','Wealthtime Select':'Wealthtime','Seven Investment Management':'7IM'};
    rPlat = platMap[rPlat] || rPlat;
    if (platform && rPlat && rPlat !== platform) return;
    var n = _normR(r[intNameCol] || '');
    if (n) intNames.add(n);
    if (intIdCol && r[intIdCol]) intIds.add((r[intIdCol] || '').toString().toLowerCase());
  });
  var errByName = {};
  var errById   = {};
  db.errors.forEach(function(e) {
    if (platform && e.platform !== platform) return;
    if (e.client) {
      var k = _normR(e.client);
      if (!errByName[k]) errByName[k] = [];
      errByName[k].push(e);
    }
    if (e.accountId) {
      var k2 = e.accountId.toLowerCase();
      if (!errById[k2]) errById[k2] = [];
      errById[k2].push(e);
    }
    if (e.clientId) {
      var k3 = e.clientId.toLowerCase();
      if (!errById[k3]) errById[k3] = [];
      errById[k3].push(e);
    }
  });
  _reconResults = _reconRows.map(function(row) {
    var platName = (row[nameCol] || '').toString().trim();
    var platId   = idCol ? (row[idCol] || '').toString().trim() : '';
    var normName = _normR(platName);
    if (platName.indexOf(',') > 0) {
      var parts = platName.split(',');
      normName = _normR(parts[1].trim() + ' ' + parts[0].trim());
    }
    var normId = platId.toLowerCase();
    var inInt  = intNames.has(normName) || (platId && intIds.has(normId));
    var errs   = (errByName[normName] || []).concat(platId ? (errById[normId] || []) : []);
    errs = errs.filter(function(v, i, a) { return a.indexOf(v) === i; });
    return {
      platName: platName,
      platId: platId,
      normName: normName,
      status: inInt ? 'matched' : errs.length ? 'errored' : 'missing',
      inInt: inInt,
      errors: errs
    };
  });
  _renderReconSummary();
  renderReconTbl();
  document.getElementById('rs3').style.display = 'block';
  document.getElementById('rs3').scrollIntoView({behavior: 'smooth', block: 'start'});
}

function _renderReconSummary() {
  var tot = _reconResults.length;
  var mat = _reconResults.filter(function(r) { return r.status === 'matched'; }).length;
  var err = _reconResults.filter(function(r) { return r.status === 'errored'; }).length;
  var mis = _reconResults.filter(function(r) { return r.status === 'missing'; }).length;
  var pct = tot ? Math.round(mat / tot * 100) : 0;
  document.getElementById('rmet-cards').innerHTML =
    '<div class="rmet"><div class="rmet-l">Platform accounts</div><div class="rmet-v">' + tot.toLocaleString() + '</div></div>' +
    '<div class="rmet"><div class="rmet-l">In internal dashboard</div><div class="rmet-v" style="color:#16a34a">' + mat.toLocaleString() + '</div></div>' +
    '<div class="rmet"><div class="rmet-l">Error reported</div><div class="rmet-v" style="color:#b45309">' + err.toLocaleString() + '</div></div>' +
    '<div class="rmet"><div class="rmet-l">Missing &amp; silent</div><div class="rmet-v" style="color:#dc2626">' + mis.toLocaleString() + '</div></div>';
  document.getElementById('r-pfill').style.width = pct + '%';
  document.getElementById('r-plbl-l').textContent = pct + '% coverage';
  document.getElementById('r-plbl-r').textContent = mis + ' unaccounted for';
}

function renderReconTbl() {
  var fs = document.getElementById('rf-st').value;
  var fq = (document.getElementById('rf-q').value || '').toLowerCase();
  var filtered = _reconResults.filter(function(r) {
    if (fs && r.status !== fs) return false;
    if (fq && r.platName.toLowerCase().indexOf(fq) < 0 && r.platId.toLowerCase().indexOf(fq) < 0) return false;
    return true;
  });
  var tbody = document.getElementById('r-tbody');
  var empty = document.getElementById('r-empty');
  var cnt   = document.getElementById('r-count');
  if (!filtered.length) { tbody.innerHTML = ''; empty.style.display = 'block'; cnt.textContent = ''; return; }
  empty.style.display = 'none';
  var shown = filtered.slice(0, 300);
  cnt.textContent = 'Showing ' + shown.length + ' of ' + filtered.length + ' accounts';
  var sb = function(s) {
    return {matched: '<span class="st-matched">Matched</span>', errored: '<span class="st-errored">Error reported</span>', missing: '<span class="st-missing">Missing &amp; silent</span>'}[s] || '';
  };
  tbody.innerHTML = shown.map(function(r) {
    var e = r.errors[0];
    return '<tr>'
      + '<td style="font-weight:500">' + (r.platName || '—') + '</td>'
      + '<td class="mono" style="font-size:12px">' + (r.platId || '—') + '</td>'
      + '<td>' + sb(r.status) + '</td>'
      + '<td style="font-size:12px">' + (r.inInt ? '<span style="color:#16a34a;font-weight:500">&#10003; Present</span>' : '<span style="color:var(--text3)">Not found</span>') + '</td>'
      + '<td style="font-size:12px;max-width:200px">' + (e
          ? '<div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="' + e.error + '">' + e.error + '</div>'
            + '<div style="font-size:10px;color:var(--text3)">' + (e.reportLabel || '') + '</div>'
            + (r.errors.length > 1 ? '<div style="font-size:10px;color:var(--text3)">+' + (r.errors.length - 1) + ' more</div>' : '')
          : '<span style="color:var(--text3)">—</span>') + '</td>'
      + '<td>' + (e ? catBadge(e.category || 'unknown') : '—') + '</td>'
      + '</tr>';
  }).join('');
}

function exportReconCSV() {
  var fs = document.getElementById('rf-st').value;
  var rows = _reconResults.filter(function(r) { return !fs || r.status === fs; });
  var h = ['Platform client', 'Account ID', 'Status', 'In internal dashboard', 'Error report entry', 'Error category', 'Report'];
  var lines = [h.join(',')].concat(rows.map(function(r) {
    var e = r.errors[0];
    return [
      '"' + r.platName + '"',
      '"' + r.platId + '"',
      r.status,
      r.inInt ? 'Yes' : 'No',
      e ? '"' + e.error + '"' : '',
      e ? (CAT_DEFS[e.category] ? CAT_DEFS[e.category].label : '') : '',
      e ? '"' + (e.reportLabel || '') + '"' : ''
    ].join(',');
  }));
  var a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([lines.join('\n')], {type: 'text/csv'}));
  a.download = 'reconciliation.csv';
  a.click();
}

function resetRecon() {
  _reconRows = []; _reconResults = []; _internalRows = [];
  document.getElementById('ru-box').classList.remove('ok');
  document.getElementById('ru-lbl').textContent = 'e.g. Transact template report';
  document.getElementById('ru-inp').value = '';
  document.getElementById('ri-box').classList.remove('ok');
  document.getElementById('ri-lbl').textContent = 'Your Accounts export file';
  document.getElementById('ri-inp').value = '';
  document.getElementById('rs2').style.display = 'none';
  document.getElementById('rs3').style.display = 'none';
  document.getElementById('r-tbody').innerHTML = '';
  document.getElementById('rmet-cards').innerHTML = '';
}
// ── END RECONCILIATION ────────────────────────────────────────────────

// Init
populateUploaderSelect();
pf();
renderOverview();
</script>
</body>
</html>
