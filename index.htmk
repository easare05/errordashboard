<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bulk Import Error Dashboard</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');

  :root {
    --bg: #f5f4f1;
    --surface: #ffffff;
    --surface2: #f0efe9;
    --border: rgba(0,0,0,0.08);
    --border-med: rgba(0,0,0,0.14);
    --text: #1a1917;
    --text2: #6b6a65;
    --text3: #9b9a95;
    --accent: #1a1917;
    --radius: 10px;
    --radius-lg: 14px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* LAYOUT */
  .app { display: flex; min-height: 100vh; }

  .sidebar {
    width: 220px;
    flex-shrink: 0;
    background: var(--surface);
    border-right: 0.5px solid var(--border-med);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 100;
  }

  .sidebar-logo {
    padding: 24px 20px 20px;
    border-bottom: 0.5px solid var(--border);
  }
  .sidebar-logo .logo-mark {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--text2);
    margin-bottom: 2px;
  }
  .sidebar-logo .logo-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .sidebar-nav { flex: 1; padding: 12px 10px; }
  .nav-section-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text3);
    padding: 12px 10px 6px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 10px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    color: var(--text2);
    font-weight: 400;
    transition: background .15s, color .15s;
    margin-bottom: 1px;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }
  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active { background: var(--text); color: #fff; font-weight: 500; }
  .nav-item svg { width: 15px; height: 15px; flex-shrink: 0; opacity: .7; }
  .nav-item.active svg { opacity: 1; }

  .sidebar-footer {
    padding: 14px 20px;
    border-top: 0.5px solid var(--border);
    font-size: 11px;
    color: var(--text3);
  }

  .main { margin-left: 220px; padding: 32px 36px; max-width: 1200px; }

  /* VIEWS */
  .view { display: none; }
  .view.active { display: block; }

  /* PAGE HEADER */
  .page-header { margin-bottom: 28px; }
  .page-title { font-size: 22px; font-weight: 600; color: var(--text); }
  .page-sub { font-size: 13px; color: var(--text2); margin-top: 4px; }

  /* CARDS */
  .card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--border-med);
    padding: 20px 22px;
    margin-bottom: 16px;
  }
  .card-title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 14px;
  }

  /* METRICS */
  .metrics { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 12px; margin-bottom: 20px; }
  .metric {
    background: var(--surface);
    border-radius: var(--radius);
    border: 0.5px solid var(--border-med);
    padding: 16px 18px;
  }
  .metric-label { font-size: 11px; color: var(--text3); font-weight: 500; margin-bottom: 8px; }
  .metric-value { font-size: 28px; font-weight: 600; letter-spacing: -.02em; color: var(--text); }
  .metric-value.amber { color: #b45309; }

  /* GRIDS */
  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  .grid3 { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 16px; margin-bottom: 16px; }

  /* TABLE */
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th {
    text-align: left;
    padding: 10px 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: var(--text3);
    border-bottom: 0.5px solid var(--border-med);
  }
  td { padding: 10px 12px; border-bottom: 0.5px solid var(--border); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--surface2); }

  /* BADGES */
  .badge { display: inline-block; font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 99px; white-space: nowrap; }
  .b-aviva { background: #dbeafe; color: #1e40af; }
  .b-tp { background: #dcfce7; color: #166534; }
  .b-transact { background: #ede9fe; color: #5b21b6; }
  .b-wealthtime { background: #fef3c7; color: #92400e; }
  .b-quilter { background: #ffedd5; color: #9a3412; }
  .b-fidelity { background: #fce7f3; color: #9d174d; }
  .b-7im { background: #d1fae5; color: #065f46; }
  .b-sw { background: #f1f0ea; color: #3b3a36; }
  .b-abrdn { background: #ede9fe; color: #4c1d95; }
  .b-nucleus { background: #fef9c3; color: #713f12; }
  .b-unknown { background: var(--surface2); color: var(--text3); }
  .b-new { background: #fee2e2; color: #991b1b; }
  .b-recur { background: #fef3c7; color: #92400e; }
  .cat-badge { display: inline-block; font-size: 10px; font-weight: 500; padding: 2px 8px; border-radius: 99px; white-space: nowrap; }

  /* FORMS */
  input[type=text], input[type=email], select, textarea {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    padding: 8px 12px;
    border: 0.5px solid var(--border-med);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text);
    outline: none;
    transition: border-color .15s;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--text); }
  textarea { resize: vertical; width: 100%; }

  /* BUTTONS */
  button {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 8px;
    border: 0.5px solid var(--border-med);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    transition: background .15s;
  }
  button:hover { background: var(--surface2); }
  button.primary {
    background: var(--text);
    color: #fff;
    border-color: var(--text);
  }
  button.primary:hover { background: #333; }
  button.danger { color: #dc2626; }

  /* UPLOAD AREA */
  .upload-area {
    border: 1.5px dashed var(--border-med);
    border-radius: var(--radius);
    padding: 28px;
    text-align: center;
    cursor: pointer;
    color: var(--text2);
    transition: border-color .15s, background .15s;
    margin-bottom: 14px;
  }
  .upload-area:hover { border-color: var(--text); background: var(--surface2); }
  .upload-title { font-size: 15px; font-weight: 500; margin-bottom: 4px; }
  .upload-sub { font-size: 12px; color: var(--text3); }

  /* STATUS */
  .status-ok { background: #f0fdf4; color: #15803d; border: 0.5px solid #bbf7d0; font-size: 13px; padding: 10px 14px; border-radius: 8px; margin-bottom: 12px; }
  .status-warn { background: #fffbeb; color: #b45309; border: 0.5px solid #fde68a; font-size: 13px; padding: 10px 14px; border-radius: 8px; margin-bottom: 12px; }

  /* BARS */
  .bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .bar-label { width: 130px; font-size: 12px; color: var(--text2); text-align: right; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bar-track { flex: 1; background: var(--surface2); border-radius: 99px; height: 7px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 99px; transition: width .4s ease; }
  .bar-count { width: 32px; font-size: 12px; font-weight: 500; text-align: right; }

  /* FILTERS */
  .filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; align-items: center; }
  .cat-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px; }
  .cat-chip { padding: 3px 10px; border-radius: 99px; font-size: 11px; font-weight: 500; cursor: pointer; border: 1.5px solid transparent; transition: border-color .15s; }
  .cat-chip.active { border-width: 1.5px; }

  /* ACCOUNT CARD */
  .acct-card { background: var(--surface); border: 0.5px solid var(--border-med); border-radius: var(--radius-lg); padding: 18px 20px; margin-bottom: 10px; }
  .timeline-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; margin-top: 3px; }
  .timeline-line { width: 1px; background: var(--border-med); margin: 0 4px; flex-grow: 1; min-height: 16px; }
  .id-pill { display: inline-block; font-family: 'DM Mono', monospace; font-size: 11px; padding: 2px 7px; border-radius: 99px; background: var(--surface2); color: var(--text2); }
  .initials-circle { width: 38px; height: 38px; border-radius: 50%; background: #dbeafe; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 13px; color: #1e40af; flex-shrink: 0; }
  .user-avatar { border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0; }

  .search-big { font-size: 15px; padding: 12px 16px; width: 100%; border: 0.5px solid var(--border-med); border-radius: var(--radius); background: var(--surface); color: var(--text); font-family: 'DM Sans', sans-serif; margin-bottom: 16px; }
  .search-big:focus { outline: none; border-color: var(--text); }

  /* ADMIN */
  .admin-hero { background: var(--text); color: #fff; border-radius: var(--radius-lg); padding: 22px 24px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; }
  .admin-hero-title { font-size: 16px; font-weight: 600; }
  .admin-hero-sub { font-size: 12px; opacity: .6; margin-top: 3px; }
  .tab-row { display: flex; gap: 2px; margin-bottom: 16px; border-bottom: 0.5px solid var(--border-med); }
  .tab { padding: 8px 16px; font-size: 13px; cursor: pointer; border: none; background: none; color: var(--text2); border-bottom: 2px solid transparent; margin-bottom: -1px; font-family: 'DM Sans', sans-serif; font-weight: 400; transition: color .15s; }
  .tab.active { color: var(--text); font-weight: 500; border-bottom-color: var(--text); }
  .user-row { display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: 0.5px solid var(--border); }
  .user-row:last-child { border-bottom: none; }
  .platform-pill { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 99px; background: var(--surface2); color: var(--text2); margin: 2px; }
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 200; align-items: center; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--surface); border-radius: var(--radius-lg); padding: 24px; width: 380px; max-width: 90vw; box-shadow: 0 20px 60px rgba(0,0,0,.15); }
  .modal-title { font-size: 16px; font-weight: 600; margin-bottom: 16px; }
  .form-label { font-size: 11px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--text3); margin-bottom: 5px; display: block; }
  .form-group { margin-bottom: 12px; }

  .empty { color: var(--text3); font-size: 13px; text-align: center; padding: 32px; }

  /* MONO */
  .mono { font-family: 'DM Mono', monospace; }

  @media (max-width: 900px) {
    .sidebar { width: 56px; }
    .sidebar-logo, .nav-section-label, .nav-item span, .sidebar-footer { display: none; }
    .nav-item { justify-content: center; padding: 10px; }
    .main { margin-left: 56px; padding: 20px; }
    .metrics { grid-template-columns: 1fr 1fr; }
    .grid3 { grid-template-columns: 1fr; }
    .grid2 { grid-template-columns: 1fr; }
  }

  /* SORTABLE */
  th.sortable{cursor:pointer;user-select:none;white-space:nowrap}
  th.sortable:hover{color:var(--text)}
  th.sortable .si{display:inline-block;margin-left:4px;opacity:.4;font-size:10px}
  th.sortable.sort-asc .si::after{content:'▲';opacity:1}
  th.sortable.sort-desc .si::after{content:'▼';opacity:1}
  th.sortable:not(.sort-asc):not(.sort-desc) .si::after{content:'⇅'}
  /* RESOLVED */
  .rcb{width:17px;height:17px;cursor:pointer;accent-color:#16a34a}
  .st-open{background:var(--surface2);color:var(--text3);font-size:10px;font-weight:600;padding:2px 8px;border-radius:99px;white-space:nowrap}
  .st-pending{background:#fef9c3;color:#854d0e;font-size:10px;font-weight:600;padding:2px 8px;border-radius:99px;white-space:nowrap}
  tr.is-res td{opacity:.55}
  tr.is-res td:last-child,tr.is-res td:nth-last-child(2){opacity:1}
  /* COLUMN TOGGLES */
  .col-bar{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px;align-items:center}
  .col-tog{display:inline-flex;align-items:center;padding:3px 9px;border-radius:99px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid var(--border-med);background:var(--surface);color:var(--text2);user-select:none;transition:all .15s}
  .col-tog.on{background:var(--text);color:#fff;border-color:var(--text)}
  /* FILTER GRID */
  .fgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:8px;margin-bottom:12px}
  .fgrid label{display:block;font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);margin-bottom:4px}
  .fgrid select,.fgrid input{width:100%}


  /* RECONCILIATION */
  .ru{border:1.5px dashed var(--border-med);border-radius:var(--radius);padding:22px;text-align:center;cursor:pointer;color:var(--text2);transition:border-color .15s,background .15s}
  .ru:hover{border-color:var(--text);background:var(--surface2)}
  .ru.ok{border-style:solid;border-color:#16a34a;background:#f0fdf4}
  .ru.ok .rs{color:#16a34a}
  .ru .rt{font-size:13px;font-weight:600;margin-bottom:3px}
  .ru .rs{font-size:11px;color:var(--text3)}
  .fmr{display:flex;align-items:center;gap:8px;margin-bottom:8px}
  .fml{font-size:12px;font-weight:500;color:var(--text2);width:110px;flex-shrink:0}
  .st-matched{background:#dcfce7;color:#166534;font-size:10px;font-weight:600;padding:2px 8px;border-radius:99px;white-space:nowrap}
  .st-errored{background:#fef9c3;color:#854d0e;font-size:10px;font-weight:600;padding:2px 8px;border-radius:99px;white-space:nowrap}
  .st-missing{background:#fee2e2;color:#991b1b;font-size:10px;font-weight:600;padding:2px 8px;border-radius:99px;white-space:nowrap}
  .rmets{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-bottom:14px}
  .rmet{background:var(--surface);border:0.5px solid var(--border-med);border-radius:var(--radius);padding:14px 16px}
  .rmet-l{font-size:11px;color:var(--text3);font-weight:500;margin-bottom:6px}
  .rmet-v{font-size:26px;font-weight:600;letter-spacing:-.02em}
  .ptrack{background:var(--surface2);border-radius:99px;height:8px;overflow:hidden;margin-top:8px}
  .pfill{height:100%;border-radius:99px;transition:width .5s ease}

</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
</head>
<body>
<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-mark">Error tracker</div>
      <div class="logo-title">Bulk Import<br>Dashboard</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section-label">Main</div>
      <button class="nav-item active" onclick="switchView('overview')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        <span>Overview</span>
      </button>
      <button class="nav-item" onclick="switchView('upload')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <span>Upload report</span>
      </button>
      <button class="nav-item" onclick="switchView('errors')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span>Error log</span>
      </button>
      <button class="nav-item" onclick="switchView('search')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>Account lookup</span>
      </button>
      <div class="nav-section-label">Records</div>
      <button class="nav-item" onclick="switchView('history')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="12 8 12 12 14 14"/><path d="M3.05 11a9 9 0 1 0 .5-3"/><polyline points="3 4 3 11 10 11"/></svg>
        <span>Report history</span>
      </button>
      <button class="nav-item" onclick="switchView('platforms')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <span>Platform IDs</span>
      </button>
      <div class="nav-section-label">Tools</div>
      <button class="nav-item" onclick="switchView('reconcile')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
        <span>Reconcile</span>
      </button>
      <div class="nav-section-label">Settings</div>
      <button class="nav-item" onclick="switchView('admin')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        <span>Admin</span>
      </button>
    </nav>
    <div class="sidebar-footer">v1.0 &nbsp;·&nbsp; 11 platforms</div>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <!-- OVERVIEW -->
    <div id="view-overview" class="view active">
      <div class="page-header">
        <div class="page-title">Overview</div>
        <div class="page-sub">All uploaded reports and errors at a glance</div>
      </div>
      <div class="metrics">
        <div class="metric"><div class="metric-label">Total errors</div><div class="metric-value" id="ov-total">0</div></div>
        <div class="metric"><div class="metric-label">Unique accounts</div><div class="metric-value" id="ov-accounts">0</div></div>
        <div class="metric"><div class="metric-label">Reports uploaded</div><div class="metric-value" id="ov-reports">0</div></div>
        <div class="metric"><div class="metric-label">Recurring accounts</div><div class="metric-value amber" id="ov-recurring">0</div></div>
      </div>
      <div class="grid3">
        <div class="card"><div class="card-title">By platform</div><div id="ov-platform-bars"><div class="empty">No data yet</div></div></div>
        <div class="card"><div class="card-title">By error category</div><div id="ov-cat-bars"><div class="empty">No data yet</div></div></div>
        <div class="card"><div class="card-title">By resolution type</div><div id="ov-res-bars"><div class="empty">No data yet</div></div></div>
      </div>
      <div class="card"><div class="card-title">Top recurring accounts</div><div id="ov-recurring-list"><div class="empty">No data yet</div></div></div>
      <div class="card"><div class="card-title">Recent errors</div><div id="ov-recent"><div class="empty">Upload a report to see errors here</div></div></div>
    </div>

    <!-- UPLOAD -->
    <div id="view-upload" class="view">
      <div class="page-header"><div class="page-title">Upload report</div><div class="page-sub">Each error is automatically tagged with its category and resolution type</div></div>
      <div class="card">
        <div style="display:flex;gap:12px;margin-bottom:14px;flex-wrap:wrap">
          <div style="flex:1;min-width:180px">
            <label class="form-label">Uploaded by</label>
            <select id="uploader-select" style="width:100%"><option value="">Select team member...</option></select>
          </div>
          <div style="flex:2;min-width:200px">
            <label class="form-label">Report label</label>
            <input type="text" id="report-label" placeholder="e.g. March 2026 — Aviva" style="width:100%">
          </div>
        </div>
        <div class="upload-area" onclick="document.getElementById('fileIn').click()">
          <div class="upload-title">Drop .txt error report here</div>
          <div class="upload-sub">or click to browse your files</div>
          <input type="file" id="fileIn" accept=".txt" style="display:none">
        </div>
        <label class="form-label">Or paste report text</label>
        <textarea id="paste-area" rows="6" placeholder="Paste error report text here..." style="margin-bottom:12px"></textarea>
        <div style="display:flex;gap:8px">
          <button onclick="loadSample()">Load sample</button>
          <button class="primary" onclick="parseAndStore()">Store report</button>
        </div>
        <div id="upload-status" style="margin-top:12px"></div>
      </div>
    </div>

    <!-- ERROR LOG -->
    <div id="view-errors" class="view">
      <div class="page-header"><div class="page-title">Error log</div><div class="page-sub">Filter, search and export errors across all reports</div></div>
      <div class="card">
        <div class="cat-chips" id="cat-filter-chips"></div>
        <div class="fgrid">
          <div><label>Platform</label><select id="fp" onchange="pf();renderErrorLog()"><option value="">All platforms</option></select></div>
          <div><label>Error category</label><select id="fc" onchange="pf();renderErrorLog()"><option value="">All categories</option></select></div>
          <div><label>Resolution</label><select id="fr" onchange="renderErrorLog()"><option value="">All types</option><option value="auto">Auto-resolvable</option><option value="manual">Manual fix</option><option value="review">Needs review</option></select></div>
          <div><label>Status</label><select id="fst" onchange="renderErrorLog()"><option value="">All statuses</option><option value="open">Open</option><option value="resolved">Pending next import</option></select></div>
          <div><label>Report</label><select id="frep" onchange="pf();renderErrorLog()"><option value="">All reports</option></select></div>
          <div><label>Firm</label><select id="ffi" onchange="pf();renderErrorLog()"><option value="">All firms</option></select></div>
          <div><label>Adviser</label><select id="fad" onchange="pf();renderErrorLog()"><option value="">All advisers</option></select></div>
          <div><label>Client</label><select id="fcl" onchange="renderErrorLog()"><option value="">All clients</option></select></div>
        </div>
        <div style="display:flex;gap:8px;margin-bottom:12px">
          <input type="text" id="filter-search" placeholder="Free text search..." oninput="renderErrorLog()" style="flex:1">
          <button onclick="clearFilters()" style="font-size:12px;color:var(--text2)">Clear all</button>
        </div>
        <div class="col-bar">
          <span style="font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);margin-right:4px">Columns</span>
          <span class="col-tog on" data-col="0" onclick="togCol(this)">Category</span>
          <span class="col-tog on" data-col="1" onclick="togCol(this)">Platform</span>
          <span class="col-tog on" data-col="2" onclick="togCol(this)">Account ID</span>
          <span class="col-tog on" data-col="3" onclick="togCol(this)">Client</span>
          <span class="col-tog on" data-col="4" onclick="togCol(this)">Adviser</span>
          <span class="col-tog on" data-col="5" onclick="togCol(this)">Firm</span>
          <span class="col-tog on" data-col="6" onclick="togCol(this)">Report</span>
          <span class="col-tog on" data-col="7" onclick="togCol(this)">Error</span>
        </div>
        <div style="overflow-x:auto">
          <table id="elt">
            <thead><tr>
              <th class="sortable" data-key="category" onclick="sortEL(this)">Category<span class="si"></span></th>
              <th class="sortable" data-key="platform" onclick="sortEL(this)">Platform<span class="si"></span></th>
              <th class="sortable" data-key="accountId" onclick="sortEL(this)">Account ID<span class="si"></span></th>
              <th class="sortable" data-key="client" onclick="sortEL(this)">Client<span class="si"></span></th>
              <th class="sortable" data-key="adviser" onclick="sortEL(this)">Adviser<span class="si"></span></th>
              <th class="sortable" data-key="firm" onclick="sortEL(this)">Firm<span class="si"></span></th>
              <th class="sortable" data-key="reportLabel" onclick="sortEL(this)">Report<span class="si"></span></th>
              <th class="sortable" data-key="error" onclick="sortEL(this)">Error<span class="si"></span></th>
              <th>Status</th><th>Resolved</th>
            </tr></thead>
            <tbody id="error-log-body"></tbody>
          </table>
        </div>
        <div id="error-log-empty" class="empty" style="display:none">No matching errors</div>
        <div id="error-log-count" style="font-size:12px;color:var(--text3);margin-top:10px;text-align:right"></div>
      </div>
    </div>

    <!-- SEARCH -->
    <div id="view-search" class="view">
      <div class="page-header"><div class="page-title">Account lookup</div><div class="page-sub">Search by account ID, client ID, client name or adviser</div></div>
      <input class="search-big" id="acct-search" placeholder="e.g. DM2307582 or Sarah Johnson..." oninput="renderAccountSearch()">
      <div id="acct-results"><div class="empty">Type above to search the error history database</div></div>
    </div>

    <!-- HISTORY -->
    <div id="view-history" class="view">
      <div class="page-header"><div class="page-title">Report history</div><div class="page-sub">All uploaded reports with uploader and error counts</div></div>
      <div class="card"><div id="history-list"><div class="empty">No reports uploaded yet</div></div></div>
    </div>

    <!-- PLATFORMS -->
    <div id="view-platforms" class="view">
      <div class="page-header"><div class="page-title">Platform IDs</div><div class="page-sub">Account and client ID formats for all 11 platforms</div></div>
      <div class="card">
        <div style="overflow-x:auto">
        <table>
          <thead><tr><th>Platform</th><th>Account ID</th><th>Client ID</th><th>Example account</th><th>Example client</th></tr></thead>
          <tbody>
            <tr><td><span class="badge b-nucleus">Nucleus</span></td><td class="mono" style="font-size:12px">N + 6 digits</td><td class="mono" style="font-size:12px">9-digit (1XXXXXXXX)</td><td class="mono" style="font-size:12px">N349632</td><td class="mono" style="font-size:12px">100258616</td></tr>
            <tr><td><span class="badge b-aviva">Aviva</span></td><td class="mono" style="font-size:12px">DM + 7 digits</td><td class="mono" style="font-size:12px">AV + 7 digits</td><td class="mono" style="font-size:12px">DM2307582</td><td class="mono" style="font-size:12px">AV2931060</td></tr>
            <tr><td><span class="badge b-quilter">Quilter</span></td><td class="mono" style="font-size:12px">DM + 7 digits</td><td class="mono" style="font-size:12px">AC + 7 digits</td><td class="mono" style="font-size:12px">DM3019422</td><td class="mono" style="font-size:12px">AC2776919</td></tr>
            <tr><td><span class="badge b-sw">Scottish Widows</span></td><td class="mono" style="font-size:12px">DM + 7 digits</td><td class="mono" style="font-size:12px">EM + 7 digits</td><td class="mono" style="font-size:12px">DM1429368</td><td class="mono" style="font-size:12px">EM1694701</td></tr>
            <tr><td><span class="badge b-abrdn">ABRDN</span></td><td class="mono" style="font-size:12px">DM + 7 digits</td><td class="mono" style="font-size:12px">WP + 7 digits</td><td class="mono" style="font-size:12px">DM1464768</td><td class="mono" style="font-size:12px">WP1842510</td></tr>
            <tr><td><span class="badge b-fidelity">Fidelity</span></td><td class="mono" style="font-size:12px">AG/AS + 8d · 10 digits</td><td class="mono" style="font-size:12px">FID + 8 alphanum</td><td class="mono" style="font-size:12px">AG10070195</td><td class="mono" style="font-size:12px">FID9ZmxbFVO</td></tr>
            <tr><td><span class="badge b-7im">7IM</span></td><td class="mono" style="font-size:12px">IMF + 5 alphanum + D</td><td class="mono" style="font-size:12px">Title + name (display)</td><td class="mono" style="font-size:12px">IMF7GH3X D</td><td>—</td></tr>
            <tr><td><span class="badge b-tp">True Potential</span></td><td class="mono" style="font-size:12px">P + 4d-5d-5d</td><td class="mono" style="font-size:12px">UUID</td><td class="mono" style="font-size:12px">P0749-30004-03556</td><td class="mono" style="font-size:12px">2588147a-...</td></tr>
            <tr><td><span class="badge b-transact">Transact</span></td><td class="mono" style="font-size:12px">IH + 8 digits</td><td class="mono" style="font-size:12px">NNN-NNN-NNN</td><td class="mono" style="font-size:12px">IH00840082</td><td class="mono" style="font-size:12px">801-908-589</td></tr>
            <tr><td><span class="badge b-wealthtime">Wealthtime</span></td><td class="mono" style="font-size:12px">digits, 1–5</td><td class="mono" style="font-size:12px">digits, 1–5</td><td class="mono" style="font-size:12px">23831</td><td class="mono" style="font-size:12px">13848</td></tr>
          </tbody>
        </table>
        </div>
        <div style="margin-top:16px;padding:14px;background:var(--surface2);border-radius:8px;font-size:12px;color:var(--text2)">
          Four platforms share the <span class="mono">DM</span> account prefix: Aviva (<span class="mono">AV</span>), Quilter (<span class="mono">AC</span>), Scottish Widows (<span class="mono">EM</span>), ABRDN (<span class="mono">WP</span>). The client ID resolves which platform a DM account belongs to.
        </div>
        <div style="margin-top:16px">
          <label class="form-label">Test an ID</label>
          <div style="display:flex;gap:8px;align-items:center">
            <input type="text" id="test-id" placeholder="e.g. WP1842510 or N349632" style="flex:1" oninput="testPlatform()">
            <div id="test-result" style="font-size:13px;min-width:220px"></div>
          </div>
        </div>
      </div>
    </div>


    <!-- RECONCILE -->
    <div id="view-reconcile" class="view">
      <div class="page-header">
        <div class="page-title">Reconciliation</div>
        <div class="page-sub">Upload a platform client export and match it against your internal dashboard to find missing accounts and silent gaps</div>
      </div>

      <div class="card" id="rs1">
        <div class="card-title">Step 1 — Upload both files</div>
        <div style="font-size:13px;color:var(--text2);margin-bottom:16px">Upload your internal dashboard export and the platform client list. Both are needed to run the reconciliation.</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div>
            <div style="font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);margin-bottom:6px">Internal dashboard export</div>
            <div class="ru" id="ri-box" onclick="document.getElementById('ri-inp').click()">
              <div class="rt">Drop .xlsx or .csv here</div>
              <div class="rs" id="ri-lbl">Your Accounts export file</div>
            </div>
            <input type="file" id="ri-inp" accept=".xlsx,.csv" style="display:none" onchange="loadInternalFile(this)">
          </div>
          <div>
            <div style="font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);margin-bottom:6px">Platform client export</div>
            <div class="ru" id="ru-box" onclick="document.getElementById('ru-inp').click()">
              <div class="rt">Drop .xlsx or .csv here</div>
              <div class="rs" id="ru-lbl">e.g. Transact template report</div>
            </div>
            <input type="file" id="ru-inp" accept=".xlsx,.csv" style="display:none" onchange="loadPlatFile(this)">
          </div>
        </div>
      </div>
      <div class="card" id="rs2" style="display:none">
        <div class="card-title">Step 2 — Map columns &amp; select platform</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:14px">
          <div>
            <div class="fmr"><span class="fml">Client name col</span><select id="rm-name" style="flex:1"><option value="">select column</option></select></div>
            <div class="fmr"><span class="fml">Account ID col</span><select id="rm-id" style="flex:1"><option value="">optional</option></select></div>
          </div>
          <div>
            <div style="font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);margin-bottom:6px">Platform</div>
            <select id="rm-plat" style="width:100%">
              <option value="">All platforms</option>
              <option value="Aviva">Aviva</option>
              <option value="Quilter">Quilter</option>
              <option value="Scottish Widows">Scottish Widows</option>
              <option value="ABRDN">ABRDN</option>
              <option value="Fidelity">Fidelity</option>
              <option value="7IM">7IM</option>
              <option value="True Potential">True Potential</option>
              <option value="Transact">Transact</option>
              <option value="Wealthtime">Wealthtime</option>
              <option value="Nucleus">Nucleus</option>
            </select>
            <div style="font-size:11px;color:var(--text3);margin-top:5px">Scopes matching to this platform in the internal dashboard</div>
          </div>
        </div>
        <button class="primary" onclick="runRecon()">Run reconciliation</button>
      </div>
      <div id="rs3" style="display:none">
        <div class="rmets" id="rmet-cards"></div>
        <div class="ptrack"><div class="pfill" id="r-pfill" style="background:#16a34a;width:0%"></div></div>
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-top:4px;margin-bottom:14px">
          <span id="r-plbl-l"></span><span id="r-plbl-r"></span>
        </div>
        <div class="card">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px">
            <div class="card-title" style="margin:0">Results</div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
              <select id="rf-st" onchange="renderReconTbl()" style="font-size:12px">
                <option value="">All statuses</option>
                <option value="matched">Matched</option>
                <option value="errored">Error reported</option>
                <option value="missing">Missing &amp; silent</option>
              </select>
              <input type="text" id="rf-q" placeholder="Search client..." oninput="renderReconTbl()" style="width:160px;font-size:12px">
              <button onclick="exportReconCSV()" style="font-size:12px;padding:6px 12px">Export CSV</button>
            </div>
          </div>
          <div style="overflow-x:auto">
            <table><thead><tr>
              <th>Platform client</th><th>Account ID</th><th>Status</th>
              <th>In dashboard</th><th>Error report entry</th><th>Category</th>
            </tr></thead><tbody id="r-tbody"></tbody></table>
          </div>
          <div id="r-empty" class="empty" style="display:none">No results match the filter</div>
          <div id="r-count" style="font-size:12px;color:var(--text3);margin-top:8px;text-align:right"></div>
        </div>
        <div style="margin-top:8px;text-align:right">
          <button onclick="resetRecon()" style="font-size:12px;color:var(--text2)">Start new reconciliation</button>
        </div>
      </div>
    </div>
    <!-- ADMIN -->
    <div id="view-admin" class="view">
      <div class="admin-hero">
        <div>
          <div class="admin-hero-title">Admin panel</div>
          <div class="admin-hero-sub">Manage team members and track upload activity</div>
        </div>
        <button onclick="showAddUserModal()" style="background:#fff;color:#1a1917;border-color:#fff;font-weight:500">+ Add team member</button>
      </div>
      <div class="tab-row">
        <button class="tab active" onclick="adminTab('log',this)">Upload log</button>
        <button class="tab" onclick="adminTab('team',this)">Team members</button>
        <button class="tab" onclick="adminTab('coverage',this)">Platform coverage</button>
      </div>
      <div id="admin-log">
        <div class="card">
          <div class="filters">
            <select id="log-filter-user" onchange="renderAdminLog()"><option value="">All team members</option></select>
            <select id="log-filter-platform" onchange="renderAdminLog()"><option value="">All platforms</option></select>
            <input type="text" id="log-filter-search" placeholder="Search report label..." oninput="renderAdminLog()" style="width:200px">
          </div>
          <div style="overflow-x:auto">
            <table>
              <thead><tr><th>Team member</th><th>Report</th><th>Platforms</th><th>Errors</th><th>Date &amp; time</th><th>Status</th></tr></thead>
              <tbody id="admin-log-body"></tbody>
            </table>
          </div>
          <div id="admin-log-empty" class="empty" style="display:none">No upload activity yet. Select a team member when uploading reports to log activity here.</div>
        </div>
      </div>
      <div id="admin-team" style="display:none">
        <div class="card"><div id="team-list"><div class="empty">No team members added yet.</div></div></div>
      </div>
      <div id="admin-coverage" style="display:none">
        <div class="card">
          <div style="font-size:13px;color:var(--text2);margin-bottom:14px">Which team members handle each platform, and when each was last processed.</div>
          <div style="overflow-x:auto"><div id="coverage-grid"></div></div>
        </div>
      </div>
    </div>

  </main>
</div>

<!-- ADD USER MODAL -->
<div class="modal-overlay" id="add-user-modal">
  <div class="modal">
    <div class="modal-title">Add team member</div>
    <div class="form-group"><label class="form-label">Full name</label><input type="text" id="new-user-name" placeholder="e.g. Sarah Chen" style="width:100%"></div>
    <div class="form-group"><label class="form-label">Role</label><input type="text" id="new-user-role" placeholder="e.g. Data Analyst" style="width:100%"></div>
    <div class="form-group">
      <label class="form-label">Responsible platforms</label>
      <div id="platform-checkboxes" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:4px"></div>
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px">
      <button onclick="hideAddUserModal()">Cancel</button>
      <button class="primary" onclick="addUser()">Add member</button>
    </div>
  </div>
</div>

<script>
const STORAGE_KEY = 'err_v3_clean';
const ALL_PLATFORMS = ['Aviva','Quilter','Scottish Widows','ABRDN','Fidelity','7IM','True Potential','Transact','Wealthtime','Nucleus'];
const AVATAR_COLORS = ['#2563eb','#059669','#d97706','#7c3aed','#dc2626','#db2777','#0284c7','#65a30d'];

const CAT_DEFS = {
  'low-balance':       {label:'Low balance',         color:'#2563eb',bg:'#dbeafe',text:'#1e40af',resolution:'auto'},
  'adviser-match':     {label:'Adviser not matched',  color:'#d97706',bg:'#fef3c7',text:'#92400e',resolution:'manual'},
  'firm-match':        {label:'Firm not matched',     color:'#6b7280',bg:'#f3f4f6',text:'#374151',resolution:'manual'},
  'portfolio-access':  {label:'Portfolio access',     color:'#7c3aed',bg:'#ede9fe',text:'#5b21b6',resolution:'manual'},
  'isin-mismatch':     {label:'ISIN not matched',     color:'#059669',bg:'#d1fae5',text:'#065f46',resolution:'review'},
  'portfolio-mismatch':{label:'Portfolio name',       color:'#d97706',bg:'#fef3c7',text:'#92400e',resolution:'manual'},
  'duplicate-holdings':{label:'Duplicated holdings',  color:'#b45309',bg:'#fef3c7',text:'#92400e',resolution:'review'},
  'wrong-firm':        {label:'Wrong firm account',   color:'#dc2626',bg:'#fee2e2',text:'#991b1b',resolution:'manual'},
  'missing-client-id': {label:'Missing client ID',    color:'#db2777',bg:'#fce7f3',text:'#9d174d',resolution:'manual'},
  'client-import':     {label:'Client record error',  color:'#16a34a',bg:'#dcfce7',text:'#166534',resolution:'manual'},
  'unknown':           {label:'Other',                color:'#6b7280',bg:'#f3f4f6',text:'#374151',resolution:'review'},
};
const RES_META = {
  auto:   {label:'Auto-resolvable',   color:'#059669',bg:'#d1fae5',text:'#065f46'},
  manual: {label:'Manual fix required',color:'#dc2626',bg:'#fee2e2',text:'#991b1b'},
  review: {label:'Needs review',      color:'#b45309',bg:'#fef3c7',text:'#92400e'},
};

function catBadge(catId){const c=CAT_DEFS[catId]||CAT_DEFS.unknown;return`<span class="cat-badge" style="background:${c.bg};color:${c.text}">${c.label}</span>`;}

function classifyError(errorType,errorText){
  const t=(errorText||'').toLowerCase(),et=errorType||'';
  if(et==='low-balance'||t.includes('balance is less than or equal'))return'low-balance';
  if(et==='adviser-match'||t.includes("couldn't match adviser"))return'adviser-match';
  if(et==='firm-match'||t.includes("couldn't match firm"))return'firm-match';
  if(et==='portfolio-access'||t.includes("doesn't have access to portfolios"))return'portfolio-access';
  if(et==='isin-mismatch'||t.includes('isin code'))return'isin-mismatch';
  if(et==='portfolio-mismatch'||t.includes('portfolio name'))return'portfolio-mismatch';
  if(et==='duplicate-holdings'||t.includes('duplicated holdings'))return'duplicate-holdings';
  if(et==='wrong-firm'||t.includes('belongs to a client from a different firm'))return'wrong-firm';
  if(et==='missing-client-id'||t.includes('missing client identifier'))return'missing-client-id';
  if(et==='client-import'||t.includes('error inserting or updating client')||t.includes('error importing client'))return'client-import';
  return'unknown';
}

// Platform detection
function normaliseAccountId(id){if(!id)return id;return id.replace(/^(IMF[A-Z0-9]{5})\s+D$/i,'$1 D').trim();}
function normaliseFirmName(raw){if(!raw)return raw;return raw.replace(/^\d+\s+/,'').trim();}
function isNucleusClientId(id){return/^1\d{8}$/.test((id||'').trim());}
function detectClientIdPlatform(clientId){
  if(!clientId)return null;const id=clientId.trim();
  if(/^FID[A-Za-z0-9]{8}$/.test(id))return'Fidelity';
  if(/^AV\d{7}$/.test(id))return'Aviva';
  if(/^AC\d{7}$/.test(id))return'Quilter';
  if(/^EM\d{7}$/.test(id))return'Scottish Widows';
  if(/^WP\d{7}$/.test(id))return'ABRDN';
  if(/^\d{3}-\d{3}-\d{3}$/.test(id))return'Transact';
  if(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(id))return'True Potential';
  if(isNucleusClientId(id))return'Nucleus';
  if(/^\d{1,5}$/.test(id))return'Wealthtime';
  return null;
}
function detectPlatform(rawAccountId,clientId){
  const aid=normaliseAccountId((rawAccountId||'').trim());const cid=(clientId||'').trim();
  if(/^N\d{6}$/.test(aid))return'Nucleus';
  if(/^IMF[A-Z0-9]{5} D$/i.test(aid))return'7IM';
  if(/^AG\d{8}$/.test(aid))return'Fidelity';
  if(/^AS\d{8}$/.test(aid))return'Fidelity';
  if(/^\d{10}$/.test(aid))return'Fidelity';
  if(/^DM\d{7}$/.test(aid)){
    if(/^AV\d{7}$/.test(cid))return'Aviva';
    if(/^AC\d{7}$/.test(cid))return'Quilter';
    if(/^EM\d{7}$/.test(cid))return'Scottish Widows';
    if(/^WP\d{7}$/.test(cid))return'ABRDN';
    return'DM-Unknown';
  }
  if(/^IH\d{8}$/.test(aid))return'Transact';
  if(/^P1036-\d{5}-\d{5}$/.test(aid))return'Aviva';
  if(/^P\d{4}-\d{5}-\d{5}$/.test(aid))return'True Potential';
  if(/^\d{1,5}$/.test(aid))return'Wealthtime';
  const fc=detectClientIdPlatform(cid);if(fc)return fc;
  return'Unknown';
}
function isDisplayOnlyClientId(cid,cname){
  if(!cid||!cname)return false;
  if(cid.trim().toLowerCase()===cname.trim().toLowerCase())return true;
  if(/^(mr|mrs|ms|miss|dr|prof)\.?\s+/i.test(cid.trim()))return true;
  return false;
}
function inferPlatformFromFilename(f){
  const fl=f.toLowerCase();
  if(fl.includes('nucleus'))return'Nucleus';
  if(fl.includes('abrdn')||fl.includes('aberdeen'))return'ABRDN';
  if(fl.includes('wealthtime'))return'Wealthtime';
  if(fl.includes('scottish_widows')||fl.includes('scottish widows'))return'Scottish Widows';
  if(fl.includes('seven_investment')||fl.includes('7im')||fl.includes('seven investment'))return'7IM';
  if(fl.includes('fidelity'))return'Fidelity';
  if(fl.includes('quilter'))return'Quilter';
  if(fl.includes('aviva'))return'Aviva';
  if(fl.includes('transact'))return'Transact';
  if(fl.includes('true_potential')||fl.includes('truepotential'))return'True Potential';
  return null;
}
function parseExpected(text){
  let m=text.match(/^Errors\s*\((\d+)\)/im);if(m)return parseInt(m[1]);
  m=text.match(/^(\d+)\s+errors?:/im);if(m)return parseInt(m[1]);return 0;
}
function cleanError(s){return s.replace(/^"+|"+$/g,'').trim();}
function normaliseClientName(raw){if(!raw||!raw.trim())return null;return raw.replace(/\|[^|)]+/g,'').replace(/\s{2,}/g,' ').trim()||null;}

function parseReport(text){
  const lines=text.split('\n'),data=[];
  let firm=null,adviser=null,client=null,clientId=null;
  for(let raw of lines){
    const line=raw.trim();if(!line||line.startsWith('---'))continue;let m;
    if(m=line.match(/^-\s+Firm (.+?) had \d+ errors?:/)){firm=normaliseFirmName(m[1].trim());adviser=null;client=null;clientId=null;continue;}
    if(m=line.match(/^-\s+Couldn't match firm (.+?) to an existing firm/i)){const fn=normaliseFirmName(m[1].trim());data.push({firm:fn,adviser:null,client:null,clientId:null,accountId:null,error:`Couldn't match firm ${fn} to an existing firm`,platform:'Unknown',errorType:'firm-match'});continue;}
    if(m=line.match(/^-\s+Adviser (.+?) had \d+ errors?:/)){adviser=m[1].trim();client=null;clientId=null;continue;}
    if(m=line.match(/^-\s+Adviser (.+?) error:/i)){adviser=m[1].trim();continue;}
    if(m=line.match(/^-\s+Couldn't match adviser (.+?) to an existing adviser/i)){data.push({firm,adviser:m[1].trim(),client:null,clientId:null,accountId:null,error:`Couldn't match adviser ${m[1].trim()} to an existing adviser`,platform:'Unknown',errorType:'adviser-match'});continue;}
    if(m=line.match(/^-\s+Client (.+?) \(([^)]*)\) had \d+ errors?:/)){client=normaliseClientName(m[1]);clientId=isDisplayOnlyClientId(m[2].trim(),m[1])?null:m[2].trim()||null;continue;}
    if(m=line.match(/^-\s+Error importing account (.+?) and its holdings:\s*(.+)/)){
      const rawAid=m[1].trim(),aid=normaliseAccountId(rawAid),err=cleanError(m[2].trim());
      const platform=detectPlatform(rawAid,clientId);
      const et=err.toLowerCase().includes('balance is less than or equal')?'low-balance':err.toLowerCase().includes("doesn't have access")?'portfolio-access':err.toLowerCase().includes('belongs to a client from a different firm')?'wrong-firm':'account-import';
      data.push({firm,adviser,client,clientId,accountId:aid,error:err,platform,errorType:et});continue;
    }
    if(m=line.match(/^-\s+Couldn't match any holding ISIN code for account (.+)/)){const rawAid=m[1].trim(),aid=normaliseAccountId(rawAid),platform=detectPlatform(rawAid,clientId);data.push({firm,adviser,client,clientId,accountId:aid,error:`Couldn't match any holding ISIN code for account ${aid}`,platform,errorType:'isin-mismatch'});continue;}
    if(m=line.match(/^-\s+Couldn't match account (.+?) portfolio name (.+?) to an existing model portfolio/)){const rawAid=m[1].trim(),aid=normaliseAccountId(rawAid),platform=detectPlatform(rawAid,clientId);data.push({firm,adviser,client,clientId,accountId:aid,error:`Couldn't match portfolio name ${m[2].trim()} to an existing model portfolio`,platform,errorType:'portfolio-mismatch'});continue;}
    if(m=line.match(/^-\s+Account (.+?) has duplicated holdings/)){const rawAid=m[1].trim(),aid=normaliseAccountId(rawAid),platform=detectPlatform(rawAid,clientId);data.push({firm,adviser,client,clientId,accountId:aid,error:`Account ${aid} has duplicated holdings`,platform,errorType:'duplicate-holdings'});continue;}
    if(m=line.match(/^-\s+Error importing client (.+?):\s*(.+)/)){const err=cleanError(m[2].trim()),cname=normaliseClientName(m[1].trim());const et=err.toLowerCase().includes('missing client identifier')?'missing-client-id':'client-import';const platform=clientId?detectClientIdPlatform(clientId)||'Unknown':'Unknown';data.push({firm,adviser,client:cname||client,clientId,accountId:null,error:err,platform,errorType:et});continue;}
  }
  data.forEach(row=>{row.category=classifyError(row.errorType,row.error);row.resolution=CAT_DEFS[row.category]?.resolution||'review';});
  return{data,expected:parseExpected(text)};
}

// DB — localStorage only for standalone
function loadDB(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY)||'{"reports":[],"errors":[],"users":[],"uploadLog":[]}')}catch(e){return{reports:[],errors:[],users:[],uploadLog:[]};}}
function saveDB(){localStorage.setItem(STORAGE_KEY,JSON.stringify(db));}
let db=loadDB();
if(!db.users)db.users=[];if(!db.uploadLog)db.uploadLog=[];if(!db.resolved)db.resolved={};

